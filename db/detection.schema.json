{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://triangle.mesh/detection.schema.json",
  "title": "TriangleDetection",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "detection_id", "node_id", "sensor_type", "observed_at", "pps_precise",
    "signature_class", "confidence", "node_position", "time_source", "schema_version"
  ],
  "properties": {
    "detection_id": { "type": "string", "minLength": 8, "description": "UUID; idempotency key" },
    "node_id": { "type": "string", "minLength": 1 },
    "sensor_type": { "type": "string", "minLength": 1, "description": "registered string, not a closed enum" },
    "observed_at": { "type": "string", "format": "date-time" },
    "pps_precise": { "type": "boolean" },
    "signature_class": { "type": "string", "minLength": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "bearing_deg": { "type": ["number", "null"], "minimum": 0, "maximum": 360 },
    "bearing_uncertainty_deg": { "type": ["number", "null"], "minimum": 0 },
    "signal_level": { "type": ["number", "null"] },
    "remote_id_payload": { "type": ["object", "null"] },
    "raw_features": { "type": ["object", "null"] },
    "node_position": {
      "type": "object",
      "required": ["lat", "lon"],
      "properties": {
        "lat": { "type": "number", "minimum": -90, "maximum": 90 },
        "lon": { "type": "number", "minimum": -180, "maximum": 180 },
        "alt_m": { "type": ["number", "null"] }
      }
    },
    "time_source": { "type": "string", "enum": ["gnss_pps", "ntp", "system"] },
    "schema_version": { "type": "integer", "minimum": 1 },
    "relayed_via": { "type": ["string", "null"] }
  }
}
