# Copy to .env and fill in. Do NOT commit .env.

# Your demo domain. Add a DNS A record: this name -> your Hetzner server's IPv4.
DOMAIN=demo.triangletechno.com

# Shared bearer token (brain <-> console <-> nodes). Generate a strong one:
#   openssl rand -hex 16
TRIANGLE_TOKEN=change-me-to-a-random-hex

# Passcode gate (HTTP basic auth) for the whole demo.
BASIC_AUTH_USER=diana
# bcrypt hash of your passcode (NOT the plaintext). Generate it with:
#   docker run --rm caddy:2 caddy hash-password --plaintext 'YOUR-PASSCODE-HERE'
# Paste the resulting $2a$... string below (keep the quotes off; it's fine as-is in .env).
BASIC_AUTH_HASH=
