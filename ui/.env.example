# Triangle Mesh UI configuration. Copy to .env.local to override defaults.
# All are optional — the app ships working defaults and runs fully offline.

# Brain REST + WS base URL.
NEXT_PUBLIC_BRAIN_URL=http://localhost:8000

# Bearer token (also used as the WS ?token= query param).
NEXT_PUBLIC_BRAIN_TOKEN=triangle-dev-token

# OPTIONAL raster tile URL template for real basemap tiles when internet/a local
# tile server is available. Leave UNSET to use the bundled offline dark style.
# Example (local tileserver-gl): http://localhost:8080/styles/dark/{z}/{x}/{y}.png
# NEXT_PUBLIC_TILE_URL=
